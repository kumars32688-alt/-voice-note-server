<?xml version="1.0" encoding="utf-8"?>
<!-- Note detail screen - view and edit a note -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="16dp">

    <!-- Category label -->
    <TextView
        android:id="@+id/text_detail_category"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Category: General"
        android:textSize="14sp"
        android:textColor="@color/primary"
        android:textStyle="bold"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Timestamp -->
    <TextView
        android:id="@+id/text_detail_timestamp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Date"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/text_detail_category"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Editable note content -->
    <EditText
        android:id="@+id/edit_content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:gravity="top|start"
        android:textSize="16sp"
        android:textColor="@color/text_primary"
        android:background="@drawable/edit_background"
        android:padding="12dp"
        android:hint="Note content..."
        android:inputType="textMultiLine"
        app:layout_constraintTop_toBottomOf="@id/text_detail_timestamp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="72dp" />

    <!-- Save button -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_save"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:src="@android:drawable/ic_menu_save"
        android:contentDescription="Save note"
        app:fabSize="normal"
        app:backgroundTint="@color/primary"
        app:tint="@android:color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
